{
  "name": "yup-cms",
  "version": "0.4.0",
  "description": "Agent-native headless CMS. A content backend that AI agents drive as naturally as humans click a mouse.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Se-La-Via/Yup-CMS.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "setup": "tsx src/scripts/setup.ts",
    "build": "tsc -p tsconfig.build.json",
    "mcp": "tsx src/mcp/server.ts",
    "api": "tsx src/api/server.ts",
    "admin": "tsx src/admin/server.ts",
    "render": "tsx src/render/server.ts",
    "worker": "tsx src/scripts/worker.ts",
    "start:api": "node dist/api/server.js",
    "start:admin": "node dist/admin/server.js",
    "start:render": "node dist/render/server.js",
    "start:migrate": "node dist/scripts/migrate.js",
    "start:worker": "node dist/scripts/worker.js",
    "smoke:webhooks": "tsx src/scripts/smoke-webhooks.ts",
    "smoke:assets": "tsx src/scripts/smoke-assets.ts",
    "smoke:admin": "tsx src/scripts/smoke-admin.ts",
    "smoke:unique": "tsx src/scripts/smoke-unique.ts",
    "smoke:graphql": "tsx src/scripts/smoke-graphql.ts",
    "smoke:schedule": "tsx src/scripts/smoke-schedule.ts",
    "smoke:tenant": "tsx src/scripts/smoke-tenant.ts",
    "smoke:search": "tsx src/scripts/smoke-search.ts",
    "smoke:i18n": "tsx src/scripts/smoke-i18n.ts",
    "smoke:plugins": "tsx src/scripts/smoke-plugins.ts",
    "smoke:render": "tsx src/scripts/smoke-render.ts",
    "smoke:assistant": "tsx src/scripts/smoke-assistant.ts",
    "smoke:marketplace": "tsx src/scripts/smoke-marketplace.ts",
    "smoke:ratelimit-redis": "tsx src/scripts/smoke-ratelimit-redis.ts",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx src/scripts/seed.ts",
    "demo": "tsx src/scripts/demo.ts",
    "plugin:add": "tsx src/scripts/plugin-add.ts",
    "marketplace:seed": "tsx src/scripts/marketplace-seed.ts",
    "webhook:listen": "tsx src/scripts/webhook-listener.ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.70.0",
    "@aws-sdk/client-s3": "^3.668.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.0",
    "graphql": "^16.9.0",
    "ioredis": "^5.4.1",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
