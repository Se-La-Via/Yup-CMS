# Copy to .env (or run `npm run setup`) and adjust.

# --- Database ---
# Used by docker-compose to provision Postgres.
POSTGRES_USER=yup
POSTGRES_PASSWORD=change-me
POSTGRES_DB=yup
# Host port Postgres is exposed on (compose).
POSTGRES_PORT=5432

# Connection string used by tools run on the HOST (npm run api/seed/migrate).
# Inside docker-compose the API container overrides this to point at host "db".
# Local Docker example below; for a managed DB (e.g. Supabase) paste its URL.
DATABASE_URL=postgres://yup:change-me@localhost:5432/yup

# --- Principal (trusted identity for writes) ---
# Who/what this server acts as. The MCP server stamps every write with this
# identity — it is NOT taken from request arguments, so it cannot be spoofed.
# An "agent" principal is held by the review gate and cannot approve reviews;
# use "human" or "system" for a trusted operator/automation connection.
CMS_PRINCIPAL_TYPE=agent
CMS_PRINCIPAL_ID=yup-agent
# Tenant (workspace) this MCP connection operates in. Defaults to "default".
# Create more with the create_tenant tool and point separate connections at them.
CMS_TENANT=default

# --- Webhook worker ---
# How often the delivery worker polls the outbox (milliseconds).
CMS_WORKER_INTERVAL_MS=2000

# --- Assets / media ---
# Storage backend for uploaded files: "local" or "s3".
CMS_STORAGE_BACKEND=local
# Directory for the local backend. For the MCP uploader and the read API to
# share files, both must point here (a shared volume in multi-container setups).
CMS_STORAGE_DIR=./storage
# Maximum upload size in bytes (default 10 MB).
CMS_MAX_ASSET_BYTES=10000000

# S3-compatible backend (AWS S3, MinIO, Cloudflare R2, Supabase Storage).
# Used when CMS_STORAGE_BACKEND=s3.
# CMS_S3_BUCKET=yup-assets
# CMS_S3_REGION=us-east-1
# CMS_S3_ENDPOINT=https://s3.example.com   # omit for AWS; set for MinIO/R2/etc.
# CMS_S3_FORCE_PATH_STYLE=true             # true for MinIO and most non-AWS
# CMS_S3_ACCESS_KEY_ID=...                 # omit to use the default IAM chain
# CMS_S3_SECRET_ACCESS_KEY=...

# --- Read API ---
CMS_API_PORT=3000
# When true, EVERY read requires a valid API key (default: only non-published
# reads require one; published content stays public).
CMS_REQUIRE_API_KEY=false
# Rate limit for the read API: max requests per window per client IP.
# Set to 0 to disable. Default: 120 requests / 60s.
CMS_RATE_LIMIT=120
CMS_RATE_WINDOW_MS=60000
# Rate-limit backend: "memory" (per-process) or "redis" (shared across instances).
CMS_RATE_BACKEND=memory
# CMS_REDIS_URL=redis://localhost:6379   # required when CMS_RATE_BACKEND=redis

# --- Admin dashboard ---
# Port for the admin server (npm run admin). Every /api route requires an
# admin-scoped API key (mint one with the MCP tool create_api_key).
CMS_ADMIN_PORT=3001

# --- Admin copilot (AI assistant in the dashboard) ---
# Set an Anthropic API key to enable the copilot. Without it, the Assistant tab
# reports "not configured"; the rest of the admin works normally.
# ANTHROPIC_API_KEY=sk-ant-...
CMS_ASSISTANT_MODEL=claude-opus-4-8

# --- Rendering (optional HTML pages) ---
CMS_RENDER_PORT=3002
# Theme name (default "default"); custom themes register themselves on load.
CMS_THEME=default
# Tenant the render server serves (slug). Defaults to "default".
# CMS_RENDER_TENANT=default
